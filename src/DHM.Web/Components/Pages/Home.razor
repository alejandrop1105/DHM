@page "/"
@inject IDashboardService DashboardService
@inject ITenantService TenantService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Dashboard - DHM</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    Dashboard de Salud
</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Monitoreo en tiempo real de la integridad de datos de tus clientes
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_dashboards.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No hay tenants configurados aún.
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenants">Crear Tenant</MudButton>
    </MudAlert>
}
else
{
    @* Resumen Global *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h4" Color="Color.Primary" Class="mt-2">@_dashboards.Count</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tenants Activos</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Science" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h4" Color="Color.Info" Class="mt-2">@_dashboards.Sum(d => d.TotalTests)</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tests Totales</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h4" Color="Color.Success" Class="mt-2">@_dashboards.Sum(d => d.PassedTests)</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tests OK</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h4" Color="Color.Error" Class="mt-2">@_dashboards.Sum(d => d.FailedTests)</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Tests Fallidos</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Tarjetas por Tenant *@
    <MudText Typo="Typo.h6" Class="mb-3">Estado por Tenant</MudText>
    <MudGrid>
        @foreach (var dashboard in _dashboards)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudCard Elevation="3" Style="border-radius: 12px; overflow: hidden;">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="@(dashboard.HealthScore >= 80 ? Color.Success : dashboard.HealthScore >= 50 ? Color.Warning : Color.Error)"
                                       Size="Size.Large">
                                @((int)dashboard.HealthScore)%
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@dashboard.TenantName</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                @dashboard.PassedTests/@dashboard.TotalTests tests pasando
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudProgressLinear Color="@(dashboard.HealthScore >= 80 ? Color.Success : dashboard.HealthScore >= 50 ? Color.Warning : Color.Error)"
                                           Value="@dashboard.HealthScore" Class="mb-3" Rounded="true" Size="Size.Large">
                            <MudText Typo="Typo.caption"><b>@dashboard.HealthScore%</b> salud</MudText>
                        </MudProgressLinear>

                        @* Semáforos por test *@
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var card in dashboard.TestCards)
                            {
                                <MudTooltip Text="@($"{card.TestName}: {(card.IsPassing ? "OK" : card.LastErrorMessage ?? "FALLO")}")">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(card.IsPassing ? Color.Success : Color.Error)"
                                             Icon="@(card.IsPassing ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)">
                                        @card.TestName
                                    </MudChip>
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   Href="@($"/analytics?tenantId={dashboard.TenantId}")">
                            Ver Tendencias
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<DashboardDto> _dashboards = new();
    private bool _loading = true;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardsAsync();
        await SetupSignalRAsync();
    }

    private async Task LoadDashboardsAsync()
    {
        _loading = true;
        try
        {
            _dashboards = (await DashboardService.GetAllDashboardsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando dashboards: {ex.Message}");
        }
        _loading = false;
    }

    private async Task SetupSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/monitorhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<object>("GlobalDashboardUpdated", async (_) =>
        {
            await LoadDashboardsAsync();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinDashboardGroup");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error conectando SignalR: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.SendAsync("LeaveDashboardGroup");
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
