@using DHM.Application.DTOs

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudTextField @bind-Value="Query.Name" Label="Nombre de la Consulta" Required="true" 
                          RequiredError="El nombre es requerido" Variant="Variant.Outlined" Class="mb-3" />

            <MudAutocomplete T="string" @bind-Value="Query.GroupName" Label="Grupo (Opcional)"
                             Variant="Variant.Outlined" Class="mb-3"
                             SearchFunc="SearchGroups" ResetValueOnEmptyText="true" Clearable="true"
                             Placeholder="Sin grupo" CoerceText="true"
                             HelperText="Escribí un nombre nuevo o elegí uno existente" />

            <MudTextField @bind-Value="Query.Description" Label="Descripción (Opcional)" 
                          Variant="Variant.Outlined" Lines="2" Class="mb-3" />
            
            @if (AvailableTenants.Any())
            {
                <MudSelect T="Guid" Label="Tenants a ejecutar" MultiSelection="true" @bind-SelectedValues="_selectedTenantIds"
                           Variant="Variant.Outlined" Class="mb-3"
                           MultiSelectionTextFunc="@(values => string.Join(", ", AvailableTenants.Where(t => _selectedTenantIds.Contains(t.Id)).Select(t => t.Name)))"
                           HelperText="Los tenants se cargarán automáticamente al elegir esta consulta.">
                    @foreach (var t in AvailableTenants)
                    {
                        <MudSelectItem T="Guid" Value="@t.Id">
                            <div class="d-flex align-center gap-2">
                                <span>@t.Name</span>
                                @if (t.Tags != null && t.Tags.Any())
                                {
                                    <div class="d-flex flex-wrap gap-1 ml-auto">
                                        @foreach (var tag in t.Tags.OrderBy(tg => tg.Name))
                                        {
                                            <div style="@($"border: 1px solid {tag.Color}; color: {tag.Color}; font-size: 0.70rem; padding: 0px 6px; border-radius: 12px;")">
                                                @tag.Name
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_formValid)">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public SavedQueryDto Query { get; set; } = new();
    [Parameter] public List<TenantDto> AvailableTenants { get; set; } = new();
    [Parameter] public List<string> ExistingGroups { get; set; } = new();

    private MudForm _form = null!;
    private bool _formValid;
    private IReadOnlyCollection<Guid> _selectedTenantIds { get; set; } = new HashSet<Guid>();

    protected override void OnParametersSet()
    {
        _selectedTenantIds = Query.SelectedTenantIds.Any()
            ? new HashSet<Guid>(Query.SelectedTenantIds)
            : new HashSet<Guid>();
    }

    private Task<IEnumerable<string>> SearchGroups(string value, CancellationToken token)
    {
        var results = ExistingGroups
            .Where(g => string.IsNullOrEmpty(value) || g.Contains(value, StringComparison.OrdinalIgnoreCase))
            .AsEnumerable();
        return Task.FromResult(results);
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (_formValid)
        {
            Query.SelectedTenantIds = _selectedTenantIds.ToList();
            MudDialog.Close(DialogResult.Ok(Query));
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
