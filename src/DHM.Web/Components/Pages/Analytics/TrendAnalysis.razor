@page "/analytics"
@inject IDashboardService DashboardService
@inject ITenantService TenantService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Análisis de Tendencias - DHM</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
    Análisis de Tendencias
</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Visualiza la evolución de la salud de datos a lo largo del tiempo
</MudText>

<MudStack Row="true" Class="mb-4" Spacing="2" AlignItems="AlignItems.Center">
    <MudSelect T="Guid?" Value="_selectedTenantId" Label="Seleccionar Tenant"
               Variant="Variant.Outlined" Dense="true" Style="min-width: 300px;"
               ValueChanged="@(async (Guid? v) => { _selectedTenantId = v; await LoadAnalyticsAsync(); })">
        @foreach (var tenant in _tenants)
        {
            <MudSelectItem T="Guid?" Value="@tenant.Id">@tenant.Name</MudSelectItem>
        }
    </MudSelect>

    <MudSelect T="int" Value="_days" Label="Período" Variant="Variant.Outlined" Dense="true"
               Style="min-width: 150px;" ValueChanged="@(async (int v) => { _days = v; if (_selectedTenantId.HasValue) await LoadAnalyticsAsync(); })">
        <MudSelectItem T="int" Value="1">Último día</MudSelectItem>
        <MudSelectItem T="int" Value="7">Última semana</MudSelectItem>
        <MudSelectItem T="int" Value="30">Último mes</MudSelectItem>
        <MudSelectItem T="int" Value="90">Últimos 3 meses</MudSelectItem>
    </MudSelect>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_selectedTenantId is null)
{
    <MudAlert Severity="Severity.Info">Selecciona un tenant para ver sus tendencias</MudAlert>
}
else if (_dashboard is not null)
{
    @* Score actual *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">SCORE DE SALUD (24H)</MudText>
                <MudText Typo="Typo.h2" Color="@GetScoreColor(_dashboard.HealthScore)" Class="mt-2">
                    @_dashboard.HealthScore%
                </MudText>
                <MudProgressLinear Color="@GetScoreColor(_dashboard.HealthScore)" Rounded="true" Size="Size.Large"
                                   Value="@_dashboard.HealthScore" Class="mt-3" Style="width: 100%;" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">TESTS PASANDO</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Baseline" Class="mt-2">
                    <MudText Typo="Typo.h2" Color="Color.Success">@_dashboard.PassedTests</MudText>
                    <MudText Typo="Typo.h5" Class="mud-text-secondary">/ @_dashboard.TotalTests</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center" Style="border-radius: 12px;">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">TESTS FALLANDO</MudText>
                <MudText Typo="Typo.h2" Color="@(_dashboard.FailedTests > 0 ? Color.Error : Color.Success)" Class="mt-2">
                    @_dashboard.FailedTests
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Gráfico de tendencia de fallos *@
    @if (_trendData.Count > 0)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="mr-1" />
                Tendencia de Fallos
            </MudText>
            <MudChart ChartType="ChartType.Line" ChartSeries="@_failChartSeries" XAxisLabels="@_chartLabels"
                      Width="100%" Height="300px" ChartOptions="_chartOptions" />
        </MudPaper>

        <MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-1" />
                Evolución del Score de Salud
            </MudText>
            <MudChart ChartType="ChartType.Line" ChartSeries="@_scoreChartSeries" XAxisLabels="@_chartLabels"
                      Width="100%" Height="300px" ChartOptions="_scoreChartOptions" />
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            No hay datos de tendencia para el período seleccionado. Los datos se acumulan a medida que los tests se ejecutan.
        </MudAlert>
    }

    @* Detalle por test *@
    <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px;">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-1" />
            Estado Actual de Tests
        </MudText>
        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <thead>
                <tr>
                    <th>Test</th>
                    <th>Estado</th>
                    <th>Último Resultado</th>
                    <th>Última Ejecución</th>
                    <th>Duración</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var card in _dashboard.TestCards)
                {
                    <tr>
                        <td><b>@card.TestName</b></td>
                        <td>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(card.IsPassing ? Color.Success : Color.Error)"
                                     Icon="@(card.IsPassing ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)">
                                @(card.IsPassing ? "OK" : "FALLO")
                            </MudChip>
                        </td>
                        <td>
                            @if (card.IsPassing)
                            {
                                <MudText Typo="Typo.body2">@(card.LastResultValue ?? "-")</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Error">@(card.LastErrorMessage ?? card.LastResultValue ?? "-")</MudText>
                            }
                        </td>
                        <td>@(card.LastExecutedAt?.ToLocalTime().ToString("dd/MM HH:mm:ss") ?? "Nunca")</td>
                        <td>@(card.LastDurationMs)ms</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private List<TenantDto> _tenants = new();
    private Guid? _selectedTenantId;
    private int _days = 7;
    private bool _loading;
    private DashboardDto? _dashboard;
    private List<TrendDataPoint> _trendData = new();

    private List<ChartSeries<double>> _failChartSeries = new();
    private List<ChartSeries<double>> _scoreChartSeries = new();
    private string[] _chartLabels = Array.Empty<string>();

    private readonly ChartOptions _chartOptions = new();

    private readonly ChartOptions _scoreChartOptions = new();

    private HubConnection? _hubConnection;

    [SupplyParameterFromQuery(Name = "tenantId")]
    public string? TenantIdParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _tenants = (await TenantService.GetAllAsync()).ToList();

        if (!string.IsNullOrEmpty(TenantIdParam) && Guid.TryParse(TenantIdParam, out var tenantId))
        {
            _selectedTenantId = tenantId;
            await LoadAnalyticsAsync();
        }

        await SetupSignalRAsync();
    }



    private async Task LoadAnalyticsAsync()
    {
        if (!_selectedTenantId.HasValue) return;

        _loading = true;
        StateHasChanged();

        try
        {
            _dashboard = await DashboardService.GetDashboardAsync(_selectedTenantId.Value);
            _trendData = (await DashboardService.GetTrendDataAsync(_selectedTenantId.Value, _days)).ToList();
            BuildChartData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }

        _loading = false;
        StateHasChanged();
    }

    private void BuildChartData()
    {
        if (_trendData.Count == 0)
        {
            _chartLabels = Array.Empty<string>();
            _failChartSeries = new List<ChartSeries<double>>();
            _scoreChartSeries = new List<ChartSeries<double>>();
            return;
        }

        _chartLabels = _trendData.Select(t => t.Date.ToString("dd/MM")).ToArray();

        _failChartSeries = new List<ChartSeries<double>>
        {
            new() { Name = "Fallos", Data = _trendData.Select(t => (double)t.FailCount).ToArray() },
            new() { Name = "Éxitos", Data = _trendData.Select(t => (double)t.PassCount).ToArray() }
        };

        _scoreChartSeries = new List<ChartSeries<double>>
        {
            new() { Name = "Score Salud (%)", Data = _trendData.Select(t => t.HealthScore).ToArray() }
        };
    }

    private async Task SetupSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/monitorhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<object>("DashboardUpdated", async (_) =>
        {
            if (_selectedTenantId.HasValue)
            {
                await LoadAnalyticsAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch { }
    }

    private static Color GetScoreColor(double score)
    {
        if (score >= 80) return Color.Success;
        if (score >= 50) return Color.Warning;
        return Color.Error;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try { await _hubConnection.DisposeAsync(); } catch { }
        }
    }
}
