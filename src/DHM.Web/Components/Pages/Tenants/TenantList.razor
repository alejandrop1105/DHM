@page "/tenants"
@using DHM.Application.DTOs
@using DHM.Application.Interfaces
@inject ITenantService TenantService
@inject ITagService TagService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Tenants - DHM</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
    Gestión de Tenants
</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
    Administra los clientes y sus bases de datos monitoreadas
</MudText>

@if (!_loading)
{
    <div class="d-flex flex-wrap gap-3 mb-4">
        <MudPaper Elevation="1" Class="pa-3 d-flex align-center gap-2" Style="border-radius: 10px; min-width: 130px;">
            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Size="Size.Small" />
            <div>
                <MudText Typo="Typo.h5" Style="line-height: 1; font-weight: 700;">@_tenants.Count</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Totales</MudText>
            </div>
        </MudPaper>
        <MudPaper Elevation="1" Class="pa-3 d-flex align-center gap-2" Style="border-radius: 10px; min-width: 130px;">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            <div>
                <MudText Typo="Typo.h5" Style="line-height: 1; font-weight: 700;">@_tenants.Count(t => t.IsActive)</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Activos</MudText>
            </div>
        </MudPaper>
        <MudPaper Elevation="1" Class="pa-3 d-flex align-center gap-2" Style="border-radius: 10px; min-width: 130px;">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Default" Size="Size.Small" />
            <div>
                <MudText Typo="Typo.h5" Style="line-height: 1; font-weight: 700;">@_tenants.Count(t => !t.IsActive)</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Inactivos</MudText>
            </div>
        </MudPaper>
        @if (_selectedFilterTags.Any())
        {
            <MudPaper Elevation="1" Class="pa-3 d-flex align-center gap-2" Style="border-radius: 10px; min-width: 130px; border: 1px solid var(--mud-palette-primary);">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Color="Color.Primary" Size="Size.Small" />
                <div>
                    <MudText Typo="Typo.h5" Style="line-height: 1; font-weight: 700;">@FilteredTenants.Count()</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Filtrados</MudText>
                </div>
            </MudPaper>
        }
    </div>
}

<MudPaper Elevation="0" Class="pa-4 mb-4 d-flex flex-wrap align-center gap-4" Style="background-color: transparent;">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog">
        Nuevo Tenant
    </MudButton>

    <MudSpacer />

    <MudToggleGroup T="ViewMode" @bind-Value="_currentView" Outline="true" Delimiters="true" Dense="true" CheckMark="false" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary">
        <MudToggleItem Value="@ViewMode.Table" UnselectedIcon="@Icons.Material.Outlined.TableRows" SelectedIcon="@Icons.Material.Filled.TableRows" />
        <MudToggleItem Value="@ViewMode.Cards" UnselectedIcon="@Icons.Material.Outlined.GridView" SelectedIcon="@Icons.Material.Filled.GridView" />
    </MudToggleGroup>

    @if (_currentView == ViewMode.Cards)
    {
        <MudToggleGroup T="CardSize" @bind-Value="_cardSize" Outline="true" Delimiters="true" Dense="true" CheckMark="false" SelectionMode="SelectionMode.SingleSelection" Color="Color.Secondary">
            <MudToggleItem Value="@CardSize.Small" UnselectedIcon="@Icons.Material.Outlined.ViewModule" SelectedIcon="@Icons.Material.Filled.ViewModule" Title="Pequeño" />
            <MudToggleItem Value="@CardSize.Medium" UnselectedIcon="@Icons.Material.Outlined.ViewComfy" SelectedIcon="@Icons.Material.Filled.ViewComfy" Title="Mediano" />
            <MudToggleItem Value="@CardSize.Large" UnselectedIcon="@Icons.Material.Outlined.ViewQuilt" SelectedIcon="@Icons.Material.Filled.ViewQuilt" Title="Grande" />
        </MudToggleGroup>
    }

    <MudSelect T="TagDto" Label="Filtrar por Etiquetas" MultiSelection="true" @bind-SelectedValues="_selectedFilterTags"
               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Class="flex-grow-0" Style="min-width: 250px;"
               ToStringFunc="@(t => t?.Name)" Clearable="true" Dense="true">
        @foreach (var group in _availableTags.GroupBy(t => t.GroupName).OrderBy(g => g.Key))
        {
            <MudSelectItem T="TagDto" Disabled="true" Class="mud-text-secondary mt-1 mb-1">
                <b>@(string.IsNullOrEmpty(group.Key) ? "Sin grupo" : group.Key)</b>
            </MudSelectItem>
            @foreach (var tag in group.OrderBy(t => t.Name))
            {
                <MudSelectItem T="TagDto" Value="@tag">
                    <div class="d-flex align-center pl-3">
                        <MudIcon Icon="@Icons.Material.Filled.Label" Style="@($"color: {tag.Color};")" Size="Size.Small" Class="mr-2" />
                        @tag.Name
                    </div>
                </MudSelectItem>
            }
        }
    </MudSelect>

    @if (_selectedTenants.Any())
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="DeleteSelectedTenants" Class="animate__animated animate__fadeIn">
            Eliminar seleccionados (@_selectedTenants.Count)
        </MudButton>
    }
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    @if (_currentView == ViewMode.Table)
    {
        <MudTable Items="@FilteredTenants" Hover="true" Elevation="2" Dense="true" Striped="true"
                  MultiSelection="true" @bind-SelectedItems="_selectedTenants"
                  Style="border-radius: 12px;">
            <HeaderContent>
                <MudTh>Nombre</MudTh>
                <MudTh>Etiquetas</MudTh>
                <MudTh>Proveedor</MudTh>
                <MudTh>Activo</MudTh>
                <MudTh>Creado</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nombre">
                    <MudText Typo="Typo.body1"><b>@context.Name</b></MudText>
                </MudTd>
                <MudTd DataLabel="Etiquetas">
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var tag in context.Tags)
                        {
                            <MudChip T="string" Size="Size.Small" Style="@($"background-color: {tag.Color}; color: white; font-size: 10px; height: 18px;")">
                                @tag.Name
                            </MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Proveedor">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.DatabaseProvider</MudChip>
                </MudTd>
                <MudTd DataLabel="Activo">
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? "Sí" : "No")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Creado">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Wifi" Color="Color.Info" Size="Size.Small"
                                   OnClick="@(() => TestConnection(context))" Title="Probar Conexión" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" Title="Editar" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteTenant(context))" Title="Eliminar" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Align="Align.Center" Class="pa-4">No se encontraron tenants con los criterios seleccionados</MudText>
            </NoRecordsContent>
        </MudTable>
    }
    else
    {
        <MudGrid Spacing="3">
            @if (!FilteredTenants.Any())
            {
                <MudItem xs="12">
                    <MudText Align="Align.Center" Class="pa-4">No se encontraron tenants con los criterios seleccionados</MudText>
                </MudItem>
            }
            else
            {
                @foreach (var tenant in FilteredTenants)
                {
                    <MudItem xs="@(GetGridSize(_cardSize, "xs"))" 
                             sm="@(GetGridSize(_cardSize, "sm"))" 
                             md="@(GetGridSize(_cardSize, "md"))" 
                             lg="@(GetGridSize(_cardSize, "lg"))">
                        <MudCard Elevation="2" Style="border-radius: 12px; height: 100%;" Class="d-flex flex-column">
                            <MudCardContent Class="@($"flex-grow-1 {(_cardSize == CardSize.Small ? "pa-2" : "pa-4")}")">
                                <div class="d-flex justify-space-between align-start mb-2">
                                    <MudText Typo="@(_cardSize == CardSize.Small ? Typo.body1 : Typo.h6)" Class="flex-grow-1" Style="word-break: break-all;">@tenant.Name</MudText>
                                    <span style="font-size: 18px; color: @(tenant.IsActive ? "#4caf50" : "#9e9e9e"); line-height: 1; flex-shrink: 0;" title="@(tenant.IsActive ? "Activo" : "Inactivo")">●</span>
                                </div>
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    @foreach (var tag in tenant.Tags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Style="@($"background-color: {tag.Color}; color: white; border-radius: 4px; font-size: {(_cardSize == CardSize.Small ? "9px" : "11px")};")">
                                            @tag.Name
                                        </MudChip>
                                    }
                                </div>
                                @if (_cardSize != CardSize.Small)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@tenant.DatabaseProvider</MudText>
                                }
                            </MudCardContent>
                            <MudCardActions Class="d-flex justify-end gap-1 pa-2">
                                <MudIconButton Icon="@Icons.Material.Filled.Wifi" Color="Color.Info" Size="Size.Small"
                                               OnClick="@(() => TestConnection(tenant))" Title="Probar Conexión" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => OpenEditDialog(tenant))" Title="Editar" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => DeleteTenant(tenant))" Title="Eliminar" />
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            }
        </MudGrid>
    }
}

@code {
    private enum ViewMode { Table, Cards }
    private enum CardSize { Small, Medium, Large }
    
    private ViewMode _currentView = ViewMode.Table;
    private CardSize _cardSize = CardSize.Medium;

    private List<TenantDto> _tenants = new();
    private HashSet<TenantDto> _selectedTenants = new();
    private bool _loading = true;

    private List<TagDto> _availableTags = new();
    private IReadOnlyCollection<TagDto> _selectedFilterTags = new HashSet<TagDto>();

    private IEnumerable<TenantDto> FilteredTenants => 
        _selectedFilterTags == null || !_selectedFilterTags.Any() 
            ? _tenants 
            : _tenants.Where(t => t.Tags != null && t.Tags.Any(tag => _selectedFilterTags.Any(ft => ft.Id == tag.Id)));

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
        await LoadTagsAsync();
    }

    private int GetGridSize(CardSize size, string breakpoint)
    {
        return (size, breakpoint) switch
        {
            (CardSize.Small, "xs") => 3,
            (CardSize.Small, "sm") => 3,
            (CardSize.Small, "md") => 2,
            (CardSize.Small, "lg") => 1,
            
            (CardSize.Medium, "xs") => 12,
            (CardSize.Medium, "sm") => 6,
            (CardSize.Medium, "md") => 4,
            (CardSize.Medium, "lg") => 3,
            
            (CardSize.Large, "xs") => 12,
            (CardSize.Large, "sm") => 12,
            (CardSize.Large, "md") => 6,
            (CardSize.Large, "lg") => 4,
            
            _ => 12
        };
    }

    private async Task LoadTenantsAsync()
    {
        _loading = true;
        _tenants = (await TenantService.GetAllAsync()).ToList();
        _selectedTenants.Clear();
        _loading = false;
    }

    private async Task LoadTagsAsync()
    {
        _availableTags = (await TagService.GetAllAsync()).ToList();
    }

    private async Task DeleteSelectedTenants()
    {
        var count = _selectedTenants.Count;
        var confirmed = await ConfirmDeleteAsync($"¿Estás seguro de que deseas eliminar los {count} tenants seleccionados?");
        
        if (confirmed)
        {
            _loading = true;
            try
            {
                await TenantService.DeleteBulkAsync(_selectedTenants.Select(x => x.Id));
                Snackbar.Add($"{count} tenants eliminados exitosamente", Severity.Warning);
                await LoadTenantsAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al eliminar en bloque: {ex.Message}", Severity.Error);
                _loading = false;
            }
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<TenantFormDialog>
        {
            { x => x.Tenant, new TenantDto() },
            { x => x.IsNew, true }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<TenantFormDialog>("Nuevo Tenant", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTenantsAsync();
            Snackbar.Add("Tenant creado exitosamente", Severity.Success);
        }
    }

    private async Task OpenEditDialog(TenantDto tenant)
    {
        var tenantToEdit = await TenantService.GetByIdAsync(tenant.Id);
        
        var parameters = new DialogParameters<TenantFormDialog>
        {
            { x => x.Tenant, tenantToEdit },
            { x => x.IsNew, false }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<TenantFormDialog>("Editar Tenant", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTenantsAsync();
            Snackbar.Add("Tenant actualizado exitosamente", Severity.Success);
        }
    }

    private async Task DeleteTenant(TenantDto tenant)
    {
        var confirmed = await ConfirmDeleteAsync($"¿Seguro que deseas eliminar el tenant '{tenant.Name}'?");
        if (confirmed)
        {
            await TenantService.DeleteAsync(tenant.Id);
            await LoadTenantsAsync();
            Snackbar.Add("Tenant eliminado", Severity.Warning);
        }
    }

    private async Task<bool> ConfirmDeleteAsync(string message)
    {
        var parameters = new DialogParameters<ConfirmDialog> { { x => x.Message, message } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirmar", parameters, options);
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private async Task TestConnection(TenantDto tenant)
    {
        try
        {
            var success = await TenantService.TestConnectionAsync(tenant.Id);
            if (success)
                Snackbar.Add($"Conexión exitosa a '{tenant.Name}'", Severity.Success);
            else
                Snackbar.Add($"No se pudo conectar a '{tenant.Name}'", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
