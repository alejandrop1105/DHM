@using DHM.Application.DTOs
@using DHM.Application.Interfaces
@inject ISnackbar Snackbar
@inject ITagGroupService TagGroupService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudSelect T="Guid" @bind-Value="Tag.GroupId" Label="Grupo *"
                       Required="true" RequiredError="Debe seleccionar un grupo"
                       Variant="Variant.Outlined" Class="mb-4"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var group in _groups)
                {
                    <MudSelectItem T="Guid" Value="@group.Id">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Style="@($"color: {group.Color};")" Size="Size.Small" />
                            @group.Name
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="Tag.Name" Label="Nombre de la Etiqueta"
                          Required="true" RequiredError="El nombre es requerido"
                          Variant="Variant.Outlined" Class="mb-4" />

            <MudText Typo="Typo.body2" Class="mb-2">Color</MudText>
            <MudColorPicker Label="Color de la Etiqueta" @bind-Text="Tag.Color"
                            Style="@($"color: {Tag.Color};")"
                            Placeholder="Selecciona un color"
                            Variant="Variant.Outlined" DisableToolbar="false" />

            <div class="mt-4 d-flex align-center">
                <MudText Typo="Typo.body2" Class="mr-4">Vista Previa:</MudText>
                <MudChip T="string" Style="@($"background-color: {Tag.Color}; color: white;")">@Tag.Name</MudChip>
            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="!_formValid">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public TagDto Tag { get; set; } = new();
    [Parameter] public bool IsNew { get; set; }

    private MudForm _form = default!;
    private bool _formValid;
    private List<TagGroupDto> _groups = new();

    protected override async Task OnInitializedAsync()
    {
        _groups = (await TagGroupService.GetAllAsync()).ToList();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (_formValid && Tag.GroupId != Guid.Empty)
        {
            MudDialog.Close(DialogResult.Ok(Tag));
        }
    }
}
